{
    "crons": [
        {
            "path": "/api/cron/employer-recurring-billing",
            "schedule": "0 2 * * *"
        },
        {
            "path": "/api/cron/daily-tasks",
            "schedule": "0 3 * * *"
        }
    ],
    "functions": {
        "app/api/cron/employer-recurring-billing/route.ts": {
            "maxDuration": 300
        },
        "app/api/cron/daily-tasks/route.ts": {
            "maxDuration": 300
        }
    },
    "headers": [
        {
            "source": "/_next/static/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/((?!.*\\.(?:ico$|png$|jpg$|jpeg$|webp$|gif$|svg$|woff2$|woff$|ttf$|css$|js$)).*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*)\\.(ico|png|jpg|jpeg|webp|gif|svg|woff2|woff|ttf|css|js)$",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}