  actionType     String   @map("action_type")
  actionDetails  Json     @map("action_details")
  entityType     String?  @map("entity_type")
  entityId       String?  @map("entity_id")
  oldValue       Json?    @map("old_value")
  newValue       Json?    @map("new_value")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([superAdminId])
  @@index([actionType])
  @@index([createdAt])
  @@map("crm_sync_change_logs")
}

model CrmSyncSettings {
  id                   String       @id @default(cuid())
  isGlobalSyncEnabled  Boolean      @default(true) @map("is_global_sync_enabled")
  defaultSyncDirection String       @default("app_to_ghl") @map("default_sync_direction")
  syncOnCreate         Boolean      @default(true) @map("sync_on_create")
  syncOnUpdate         Boolean      @default(true) @map("sync_on_update")
  syncBatchSize        Int          @default(50) @map("sync_batch_size")
  retryAttempts        Int          @default(3) @map("retry_attempts")
  retryDelaySeconds    Int          @default(60) @map("retry_delay_seconds")
  ghlApiKey            String?      @map("ghl_api_key")
  ghlLocationId        String?      @map("ghl_location_id")
  ghlConnectionStatus  String       @default("disconnected") @map("ghl_connection_status")
  ghlLastTested        DateTime?    @map("ghl_last_tested")
  ghlLastTestedBy      String?      @map("ghl_last_tested_by")
  lastUpdatedBy        String       @map("last_updated_by")
  lastSavedBy          String?      @unique @map("last_saved_by")
  lastSavedAt          DateTime?    @map("last_saved_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  lastSavedByUser      UserProfile? @relation("CrmSyncSettingsLastSavedBy", fields: [lastSavedBy], references: [id])

  @@map("crm_sync_settings")
}

model GhlField {
  id              String         @id @default(cuid())
  ghlFieldId      String         @unique @map("ghl_field_id")
  ghlFieldKey     String         @unique @map("ghl_field_key")
  name            String
  dataType        String         @map("data_type")
  picklistOptions Json?          @map("picklist_options")
  isSystemField   Boolean        @default(false) @map("is_system_field")
  lastSyncedAt    DateTime?      @map("last_synced_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  mappings        FieldMapping[]

  @@map("ghl_fields")
}

model AppField {
  id            String         @id @default(cuid())
  fieldKey      String         @unique @map("field_key")
  name          String
  dataType      String         @map("data_type")
  modelName     String?        @map("model_name")
  isSystemField Boolean        @default(false) @map("is_system_field")
  isRequired    Boolean        @default(false) @map("is_required")
  description   String?
  groupId       String?        @map("group_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  group         FieldGroup?    @relation(fields: [groupId], references: [id])
  mappings      FieldMapping[]

  @@index([groupId])
  @@map("app_fields")
}

model FieldGroup {
  id          String         @id @default(cuid())
  name        String
  description String?
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  appFields   AppField[]
  mappings    FieldMapping[]

  @@map("field_groups")
}

model FieldMapping {
  id              String      @id @default(cuid())
  groupId         String?     @map("group_id")
  ghlFieldId      String      @map("ghl_field_id")
  appFieldId      String      @map("app_field_id")
  syncDirection   String      @map("sync_direction")
  isEnabled       Boolean     @default(true) @map("is_enabled")
  displayLabel    String?     @map("display_label")
  transformRules  Json?       @map("transform_rules")
  createdBy       String      @map("created_by")
  updatedBy       String?     @map("updated_by")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  lastSyncedAt    DateTime?   @map("last_synced_at")
  lastSyncStatus  String?     @map("last_sync_status")
  lastSyncError   String?     @map("last_sync_error")
  isAutoGenerated Boolean     @default(false) @map("is_auto_generated")
  appField        AppField    @relation(fields: [appFieldId], references: [id], onDelete: Cascade)
  ghlField        GhlField    @relation(fields: [ghlFieldId], references: [id], onDelete: Cascade)
  group           FieldGroup? @relation(fields: [groupId], references: [id])

  @@unique([ghlFieldId, appFieldId])
  @@index([groupId])
  @@index([isEnabled])
  @@map("field_mappings")
}

model CrmSyncLog {
  id           String   @id @default(cuid())
  mappingId    String   @map("mapping_id")
  userId       String?  @map("user_id")
  direction    String
  status       String
  errorMessage String?  @map("error_message")
  dataSnapshot Json?    @map("data_snapshot")
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([mappingId])
  @@index([status])
  @@index([createdAt])
  @@map("crm_sync_logs")
}

model ExecutionLog {
  id          String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  taskName    String      @map("task_name")
  status      String      @default("running")
  startedAt   DateTime    @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?   @map("completed_at") @db.Timestamptz(6)
  durationMs  Int?        @map("duration_ms")
  summary     String?
  logOutput   String?     @map("log_output")
  triggeredBy String?     @default("system") @map("triggered_by")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  actions     ActionLog[]

  @@index([createdAt(sort: Desc)], map: "idx_execution_logs_created_at")
  @@index([status], map: "idx_execution_logs_status")
  @@index([taskName], map: "idx_execution_logs_task_name")
  @@map("execution_logs")
}

model ActionLog {
  id           String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  executionId  String?       @map("execution_id")
  actionType   String        @map("action_type")
  entityType   String?       @map("entity_type")
  entityId     String?       @map("entity_id")
  status       String
  message      String?
  details      String?
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  executionLog ExecutionLog? @relation(fields: [executionId], references: [id], onUpdate: NoAction)

  @@index([actionType], map: "idx_action_logs_action_type")
  @@index([createdAt(sort: Desc)], map: "idx_action_logs_created_at")
  @@index([entityType, entityId], map: "idx_action_logs_entity")
  @@index([executionId], map: "idx_action_logs_execution_id")
  @@index([status], map: "idx_action_logs_status")
  @@map("action_logs")
}

