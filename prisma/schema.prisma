generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserProfile {
  id                           String                       @id @default(cuid())
  stackUserId                  String?                      @unique @map("stack_user_id")
  role                         UserRole
  name                         String
  phone                        String?
  timezone                     String                       @default("America/Chicago")
  createdAt                    DateTime                     @default(now()) @map("created_at")
  updatedAt                    DateTime                     @updatedAt @map("updated_at")
  email                        String?
  profilePictureUrl            String?                      @map("profile_picture_url")
  firstName                    String?                      @map("first_name")
  lastName                     String?                      @map("last_name")
  conciergeBio                 String?                      @map("concierge_bio")
  conciergeTitle               String?                      @map("concierge_title")
  conciergeSpecialties         String[]                     @map("concierge_specialties")
  conciergeExperience          Int?                         @map("concierge_experience")
  isActiveConcierge            Boolean                      @default(false) @map("is_active_concierge")
  tags                         String[]                     @default([])
  clerkUserId                  String?                      @unique @map("clerk_user_id")
  legacyId                     BigInt?                      @unique @map("legacy_id")
  allowDirectMessages          Boolean                      @default(true) @map("allow_direct_messages")
  messageNotificationEmail     Boolean                      @default(true) @map("message_notification_email")
  messageNotificationInApp     Boolean                      @default(true) @map("message_notification_in_app")
  isActive                     Boolean?                     @default(true) @map("is_active")
  assignedServicePurchases     AdditionalServicePurchase[]  @relation("additional_service_purchases_assigned_admin_idTouser_profiles")
  servicePurchases             AdditionalServicePurchase[]  @relation("additional_service_purchases_user_idTouser_profiles")
  adminActions                 AdminActionLog[]
  subscriptionCancellationLogs SubscriptionCancellationLog[]
  conciergeChatMessages        ConciergeChatMessage[]       @relation("ConciergeChatMessageSender")
  conciergeChats               ConciergeChat[]              @relation("ConciergeChatAdmin")
  conciergeAssignments         ConciergeRequest[]           @relation("ConciergeAssignments")
  crmSyncSettingsLastSavedBy   CrmSyncSettings?             @relation("CrmSyncSettingsLastSavedBy")
  employer                     Employer?
  externalPayments             ExternalPayment[]
  jobSeeker                    JobSeeker?
  messageDrafts                MessageDraft[]
  messageTemplates             MessageTemplate[]
  receivedMessages             Message[]                    @relation("MessageRecipient")
  sentMessages                 Message[]                    @relation("MessageSender")
  notifications                Notification[]
  seekerConciergeChatMessages  SeekerConciergeChatMessage[] @relation("SeekerConciergeChatMessageSender")
  seekerConciergeChats         SeekerConciergeChat[]        @relation("SeekerConciergeChatAdmin")
  seekerConciergeChatsAsSeeker SeekerConciergeChat[]        @relation("SeekerConciergeChats")
  serviceRequestAudits         ServiceRequestAudit[]
  sentTeamInvitations          TeamInvitation[]             @relation("TeamInvitationInviter")
  teamInvitations              TeamMember[]                 @relation("TeamMemberInviter")
  teamMemberships              TeamMember[]                 @relation("TeamMemberUser")
  sentUserInvitations          UserInvitation[]             @relation("UserInvitationInviter")

  @@index([clerkUserId], map: "idx_user_profiles_clerk_user_id")
  @@index([clerkUserId])
  @@map("user_profiles")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model JobSeeker {
  userId                 String                      @id @map("user_id")
  headline               String?
  aboutMe                String?                     @map("about_me")
  availability           String?
  skills                 String[]
  portfolioUrls          String[]                    @map("portfolio_urls")
  resumeUrl              String?                     @map("resume_url")
  resumeLastUploaded     DateTime?                   @map("resume_last_uploaded")
  membershipPlan         MembershipPlan              @default(none) @map("membership_plan")
  membershipExpiresAt    DateTime?                   @map("membership_expires_at")
  isSuspended            Boolean                     @default(false) @map("is_suspended")
  createdAt              DateTime                    @default(now()) @map("created_at")
  updatedAt              DateTime                    @updatedAt @map("updated_at")
  resumeCredits          Int                         @default(0) @map("resume_credits")
  salaryExpectations     String?                     @map("salary_expectations")
  allowDirectMessages    Boolean                     @default(true) @map("allow_direct_messages")
  applicationUpdates     Boolean                     @default(true) @map("application_updates")
  emailAlerts            Boolean                     @default(true) @map("email_alerts")
  jobRecommendations     Boolean                     @default(true) @map("job_recommendations")
  profileVisibility      ProfileVisibility           @default(employers_only) @map("profile_visibility")
  showSalaryExpectations Boolean                     @default(true) @map("show_salary_expectations")
  weeklyDigest           Boolean                     @default(false) @map("weekly_digest")
  allowJobInvitations    Boolean                     @default(true) @map("allow_job_invitations")
  resumeLimit            Int                         @default(0) @map("resume_limit")
  resumesUsed            Int                         @default(0) @map("resumes_used")
  trialEndsAt            DateTime?                   @map("trial_ends_at")
  isOnTrial              Boolean                     @default(false) @map("is_on_trial")
  cancelledSeeker        Boolean                     @default(false) @map("cancelled_seeker")
  cancelledAt            DateTime?                   @map("cancelled_at")
  hasPreviousSubscription Boolean                    @default(false) @map("has_previous_subscription")
  education              Json?
  workExperience         String?                     @map("work_experience")
  professionalSummary    String?                     @map("professional_summary")
  resumeCarryoverCount   Int                         @default(0) @map("resume_carryover_count")
  lastBillingPeriodStart DateTime?                   @map("last_billing_period_start") @db.Timestamp(6)
  servicePurchases       AdditionalServicePurchase[]
  applications           Application[]
  cancellationSurveys    CancellationSurvey[]
  coverLetterTemplates   CoverLetterTemplate[]
  user                   UserProfile                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentMethods         PaymentMethod[]
  resumeCritiques        ResumeCritique[]
  resumes                Resume[]
  savedJobs              SavedJob[]
  subscriptions          Subscription[]

  @@index([membershipPlan, membershipExpiresAt], map: "idx_jobseeker_membership")
  @@index([skills], map: "idx_jobseeker_skills_gin", type: Gin)
  @@index([profileVisibility, isSuspended, updatedAt(sort: Desc)], map: "idx_jobseeker_visibility_updated")
  @@map("job_seekers")
}

model Employer {
  userId                   String                      @id @map("user_id")
  companyName              String                      @map("company_name")
  companyWebsite           String?                     @map("company_website")
  companyLogoUrl           String?                     @map("company_logo_url")
  companyDescription       String?                     @map("company_description")
  billingAddress           String?                     @map("billing_address")
  taxId                    String?                     @map("tax_id")
  currentPackageId         String?                     @map("current_package_id")
  isSuspended              Boolean                     @default(false) @map("is_suspended")
  createdAt                DateTime                    @default(now()) @map("created_at")
  updatedAt                DateTime                    @updatedAt @map("updated_at")
  isVetted                 Boolean                     @default(false) @map("is_vetted")
  vettedAt                 DateTime?                   @map("vetted_at")
  vettedBy                 String?                     @map("vetted_by")
  teamId                   String?                     @map("team_id")
  missionStatement         String?                     @map("mission_statement")
  coreValues               String?                     @map("core_values")
  exclusivePlanType        String?                     @map("exclusive_plan_type")
  exclusivePlanName        String?                     @map("exclusive_plan_name")
  exclusivePlanAmountCents Int?                        @map("exclusive_plan_amount_cents")
  exclusivePlanCycles      Int?                        @map("exclusive_plan_cycles")
  exclusivePlanOfferedAt   DateTime?                   @map("exclusive_plan_offered_at") @db.Timestamptz(6)
  exclusivePlanDismissedAt DateTime?                   @map("exclusive_plan_dismissed_at") @db.Timestamptz(6)
  exclusivePlanActivatedAt DateTime?                   @map("exclusive_plan_activated_at") @db.Timestamptz(6)
  exclusivePlanSource      String?                     @map("exclusive_plan_source")
  servicePurchases         AdditionalServicePurchase[]
  conciergeChats           ConciergeChat[]
  conciergeRequests        ConciergeRequest[]
  emailBlastRequests       EmailBlastRequest[]
  packages                 EmployerPackage[]
  currentPackage           EmployerPackage?            @relation("CurrentPackage", fields: [currentPackageId], references: [id])
  user                     UserProfile                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  featuredJobRequests      FeaturedJobRequest[]
  jobs                     Job[]
  paymentMethods           PaymentMethod[]
  teamInvitations          TeamInvitation[]
  teamMembers              TeamMember[]

  @@map("employers")
}

model EmployerPackage {
  id                        String                      @id @default(cuid())
  employerId                String                      @map("employer_id")
  jobIds                    String[]                    @map("job_ids")
  listingsRemaining         Int                         @map("listings_remaining")
  purchasedAt               DateTime                    @default(now()) @map("purchased_at")
  expiresAt                 DateTime?                   @map("expires_at")
  createdAt                 DateTime                    @default(now()) @map("created_at")
  updatedAt                 DateTime                    @updatedAt @map("updated_at")
  packageType               PackageType                 @map("package_type")
  featuredListingsRemaining Int                         @default(0) @map("featured_listings_remaining")
  featuredListingsUsed      Int                         @default(0) @map("featured_listings_used")
  isRecurring               Boolean?                    @default(false) @map("is_recurring")
  billingFrequency          String?                     @map("billing_frequency")
  billingCyclesTotal        Int?                        @map("billing_cycles_total")
  billingCyclesCompleted    Int?                        @default(0) @map("billing_cycles_completed")
  nextBillingDate           DateTime?                   @map("next_billing_date") @db.Timestamptz(6)
  recurringAmountCents      Int?                        @map("recurring_amount_cents")
  arbSubscriptionId         String?                     @map("arb_subscription_id") @db.VarChar(255)
  recurringStatus           String?                     @default("active") @map("recurring_status")
  extensionRequestedAt      DateTime?                   @map("extension_requested_at") @db.Timestamptz(6)
  extensionRequestedMonths  Int?                        @map("extension_requested_months")
  extensionRequestStatus    String?                     @map("extension_request_status")
  extensionReviewedAt       DateTime?                   @map("extension_reviewed_at") @db.Timestamptz(6)
  extensionReviewedBy       String?                     @map("extension_reviewed_by")
  addOnServiceRequests      AdditionalServicePurchase[]
  emailBlastRequests        EmailBlastRequest[]
  employer                  Employer                    @relation(fields: [employerId], references: [userId], onDelete: Cascade)
  currentForEmployers       Employer[]                  @relation("CurrentPackage")
  featuredJobRequests       FeaturedJobRequest[]
  invoices                  Invoice[]
  purchasedAddOns           PurchasedAddOn[]            @relation("PackageAddOns")
  jobs                      Job[]                       @relation("PackageJobs")

  @@index([employerId, expiresAt], map: "idx_employer_package_expires")
  @@map("employer_packages")
}

model Job {
  id                           String                @id @default(cuid())
  employerId                   String                @map("employer_id")
  title                        String
  payRangeMin                  Decimal?              @map("pay_range_min")
  payRangeMax                  Decimal?              @map("pay_range_max")
  payRangeText                 String?               @map("pay_range_text")
  type                         JobType
  description                  String
  skillsRequired               String[]              @map("skills_required")
  isFlexibleHours              Boolean               @default(false) @map("is_flexible_hours")
  hoursPerWeek                 Int?                  @map("hours_per_week")
  remoteSchedule               String?               @map("remote_schedule")
  locationText                 String?               @map("location_text")
  status                       JobStatus             @default(draft)
  rejectionReason              String?               @map("rejection_reason")
  conciergeRequested           Boolean               @default(false) @map("concierge_requested")
  conciergeStatus              ConciergeStatus       @default(not_requested) @map("concierge_status")
  createdAt                    DateTime              @default(now()) @map("created_at")
  updatedAt                    DateTime              @updatedAt @map("updated_at")
  expiresAt                    DateTime?             @map("expires_at")
  approvedAt                   DateTime?             @map("approved_at")
  benefits                     String?
  viewsCount                   Int                   @default(0) @map("views_count")
  salaryType                   String?               @map("salary_type")
  experienceLevel              String?               @map("experience_level")
  applicationDeadline          DateTime?             @map("application_deadline")
  requirements                 String?
  contactPhone                 String?               @map("contact_phone")
  linkedinProfile              String?               @map("linkedin_profile")
  website                      String?
  category                     JobCategory
  emailBlastCompletedAt        DateTime?             @map("email_blast_completed_at")
  emailBlastExpiresAt          DateTime?             @map("email_blast_expires_at")
  emailBlastRequestedAt        DateTime?             @map("email_blast_requested_at")
  emailBlastStatus             EmailBlastStatus      @default(not_requested) @map("email_blast_status")
  featuredCompletedAt          DateTime?             @map("featured_completed_at")
  featuredExtensionExpiresAt   DateTime?             @map("featured_extension_expires_at")
  featuredExtensionGranted     Boolean               @default(false) @map("featured_extension_granted")
  featuredRequestedAt          DateTime?             @map("featured_requested_at")
  featuredStatus               FeaturedStatus        @default(not_requested) @map("featured_status")
  isEmailBlast                 Boolean               @default(false) @map("is_email_blast")
  isFeatured                   Boolean               @default(false) @map("is_featured")
  isCompanyPrivate             Boolean               @default(false) @map("is_company_private")
  applicantsVisibleToEmployer  Boolean               @default(false) @map("applicants_visible_to_employer")
  applicantsVisibleLastToggled DateTime?             @map("applicants_visible_last_toggled")
  applicantsVisibleToggledBy   String?               @map("applicants_visible_toggled_by")
  chatEnabled                  Boolean               @default(false) @map("chat_enabled")
  chatEnabledAt                DateTime?             @map("chat_enabled_at")
  archivedAt                   DateTime?             @map("archived_at") @db.Timestamptz(6)
  archivedBy                   String?               @map("archived_by")
  isArchived                   Boolean?              @default(false) @map("is_archived")
  isPaused                     Boolean               @default(false) @map("is_paused")
  pausedAt                     DateTime?             @map("paused_at")
  pausedBy                     String?               @map("paused_by") @db.VarChar(255)
  pausedDaysRemaining          Int?                  @map("paused_days_remaining")
  resumedAt                    DateTime?             @map("resumed_at")
  legacyId                     BigInt?               @map("legacy_id")
  manualApprove                Boolean               @default(false) @map("manual_approve")
  applications                 Application[]
  conciergeChats               ConciergeChat[]
  conciergeRequests            ConciergeRequest[]
  emailBlastRequests           EmailBlastRequest[]
  featuredJobRequests          FeaturedJobRequest[]
  employer                     Employer              @relation(fields: [employerId], references: [userId], onDelete: Cascade)
  messages                     Message[]
  savedByUsers                 SavedJob[]
  seekerConciergeChats         SeekerConciergeChat[]
  employerPackages             EmployerPackage[]     @relation("PackageJobs")

  @@index([employerId, status], map: "idx_job_employer_status")
  @@index([createdAt], map: "idx_job_created_at")
  @@index([employerId, createdAt], map: "idx_job_employer_created")
  @@index([employerId, isArchived], map: "idx_job_employer_archived")
  @@index([category, type], map: "idx_job_category_type")
  @@index([status, expiresAt], map: "idx_job_status_expires")
  @@index([employerId, status, expiresAt], map: "idx_job_employer_status_expires")
  @@map("jobs")
}

model Application {
  id                   String             @id @default(cuid())
  jobId                String             @map("job_id")
  seekerId             String             @map("seeker_id")
  resumeUrl            String             @map("resume_url")
  coverLetter          String?            @map("cover_letter")
  status               ApplicationStatus  @default(pending)
  appliedAt            DateTime           @default(now()) @map("applied_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  interviewCompletedAt DateTime?          @map("interview_completed_at") @db.Timestamptz(6)
  interviewScheduledAt DateTime?          @map("interview_scheduled_at") @db.Timestamptz(6)
  interviewStage       InterviewStage?    @map("interview_stage")
  interviewerNotes     String?            @map("interviewer_notes")
  nextActionDeadline   DateTime?          @map("next_action_deadline") @db.Timestamptz(6)
  nextActionRequired   String?            @map("next_action_required")
  resumeId             String?            @map("resume_id") @db.VarChar(255)
  legacy_id            BigInt?
  job                  Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seeker               JobSeeker          @relation(fields: [seekerId], references: [userId], onDelete: Cascade)
  resume               Resume?            @relation("ApplicationResume", fields: [resumeId], references: [id], onUpdate: NoAction, map: "fk_applications_resume_id")
  interviewHistory     InterviewHistory[]
  messages             Message[]

  @@index([resumeId], map: "idx_applications_resume_id")
  @@map("applications")
}

model InterviewHistory {
  id            String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  applicationId String         @map("application_id")
  stage         InterviewStage
  scheduledAt   DateTime?      @map("scheduled_at") @db.Timestamptz(6)
  completedAt   DateTime?      @map("completed_at") @db.Timestamptz(6)
  notes         String?
  interviewerId String?        @map("interviewer_id")
  feedback      String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId])
  @@index([createdAt])
  @@map("interview_history")
}

model Subscription {
  id                    String               @id @default(cuid())
  seekerId              String               @map("seeker_id")
  authnetSubscriptionId String?              @map("authnet_subscription_id")
  authnetCustomerId     String?              @map("authnet_customer_id")
  plan                  MembershipPlan
  status                SubscriptionStatus   @default(active)
  currentPeriodEnd      DateTime?            @map("current_period_end")
  cancelAtPeriodEnd     Boolean              @default(false) @map("cancel_at_period_end")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  ghlTransactionId      String?              @map("ghl_transaction_id")
  externalPaymentId     String?              @map("external_payment_id")
  tier                  String?              @db.VarChar(50)
  tier_metadata         Json?                @default("{}")
  expires_at            DateTime?            @db.Timestamptz(6)
  is_legacy_beta        Boolean?             @default(false)
  currentPeriodStart    DateTime?            @map("current_period_start") @db.Timestamp(6)
  billingFrequency      String?              @map("billing_frequency") @db.VarChar(50)
  nextBillingDate       DateTime?            @map("next_billing_date") @db.Timestamp(6)
  legacyId              Float?               @map("legacy_id")
  cancellationSurveys   CancellationSurvey[]
  cancellationLogs      SubscriptionCancellationLog[]
  externalPayment       ExternalPayment?     @relation(fields: [externalPaymentId], references: [id])
  seeker                JobSeeker            @relation(fields: [seekerId], references: [userId], onDelete: Cascade)

  @@index([tier], map: "idx_subscriptions_tier")
  @@index([currentPeriodStart, currentPeriodEnd], map: "idx_subscriptions_current_period")
  @@map("subscriptions")
}

model CancellationSurvey {
  id                  String        @id @default(cuid())
  seekerId            String        @map("seeker_id")
  subscriptionId      String?       @map("subscription_id")
  primaryReason       String        @map("primary_reason")
  reasonOtherText     String?       @map("reason_other_text")
  jobSatisfaction     String        @map("job_satisfaction")
  overallExperience   String        @map("overall_experience")
  improvementFeedback String?       @map("improvement_feedback")
  recommendToOthers   String        @map("recommend_to_others")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  seeker              JobSeeker     @relation(fields: [seekerId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_cancellation_survey_seeker")
  subscription        Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cancellation_survey_subscription")

  @@index([seekerId], map: "idx_cancellation_survey_seeker_id")
  @@index([subscriptionId], map: "idx_cancellation_survey_subscription_id")
  @@index([createdAt(sort: Desc)], map: "idx_cancellation_survey_created_at")
  @@index([primaryReason], map: "idx_cancellation_survey_reason")
  @@map("cancellation_surveys")
}

model SubscriptionCancellationLog {
  id               String       @id @default(dbgenerated("gen_random_uuid()::text"))
  subscriptionId   String       @map("subscription_id")
  adminId          String       @map("admin_id")
  seekerId         String       @map("seeker_id")
  previousPeriodEnd DateTime?   @map("previous_period_end") @db.Timestamptz(6)
  newPeriodEnd     DateTime?    @map("new_period_end") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  admin            UserProfile  @relation(fields: [adminId], references: [id], onDelete: Cascade)
  subscription     Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId], map: "idx_sub_cancel_logs_subscription")
  @@index([adminId], map: "idx_sub_cancel_logs_admin")
  @@index([createdAt(sort: Desc)], map: "idx_sub_cancel_logs_created")
  @@map("subscription_cancellation_logs")
}

model ResumeCritique {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(255)
  seekerId       String            @map("seeker_id") @db.VarChar(255)
  requestedAt    DateTime          @default(now()) @map("requested_at") @db.Timestamptz(6)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  resumeUrl      String            @map("resume_url")
  analysis       Json?
  completedAt    DateTime?         @map("completed_at") @db.Timestamptz(6)
  cost           Float
  priority       critique_priority @default(standard)
  reviewerId     String?           @map("reviewer_id") @db.VarChar(255)
  targetIndustry String?           @map("target_industry") @db.VarChar(255)
  targetRole     String?           @map("target_role") @db.VarChar(255)
  status         critique_status   @default(pending)
  seeker         JobSeeker         @relation(fields: [seekerId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_resume_critique_seeker")

  @@index([requestedAt], map: "idx_resume_critiques_requested_at")
  @@index([seekerId], map: "idx_resume_critiques_seeker_id")
  @@index([status], map: "idx_resume_critiques_status")
  @@map("resume_critiques")
}

model Invoice {
  id                   String          @id @default(cuid())
  employerPackageId    String?         @map("employer_package_id")
  authnetTransactionId String?         @map("authnet_transaction_id")
  amountDue            Int             @map("amount_due")
  status               InvoiceStatus   @default(draft)
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  description          String?
  packageName          String?         @map("package_name")
  dueDate              DateTime?       @map("due_date")
  paidAt               DateTime?       @map("paid_at")
  employerPackage      EmployerPackage? @relation(fields: [employerPackageId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model PaymentMethod {
  id                      String     @id @default(cuid())
  employerId              String?    @map("employer_id")
  seekerId                String?    @map("seeker_id")
  type                    String     @default("card")
  last4                   String
  brand                   String
  expiryMonth             Int        @map("expiry_month")
  expiryYear              Int        @map("expiry_year")
  isDefault               Boolean    @default(false) @map("is_default")
  authnetPaymentProfileId String?    @map("authnet_payment_profile_id")
  billingFirstName        String?    @map("billing_first_name")
  billingLastName         String?    @map("billing_last_name")
  billingAddress          String?    @map("billing_address")
  billingCity             String?    @map("billing_city")
  billingState            String?    @map("billing_state")
  billingZipCode          String?    @map("billing_zip_code")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  is_legacy               Boolean?   @default(false)
  employer                Employer?  @relation(fields: [employerId], references: [userId], onDelete: Cascade)
  seeker                  JobSeeker? @relation(fields: [seekerId], references: [userId], onDelete: Cascade)

  @@index([seekerId])
  @@map("payment_methods")
}

model AdminActionLog {
  id           String      @id @default(cuid())
  adminId      String      @map("admin_id")
